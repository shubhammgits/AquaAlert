# Copy this file to `.env` (do NOT commit `.env`), then fill in values.

# Used to sign JWTs. Change this in production.
JWT_SECRET=change-this-to-a-long-random-string

# MongoDB connection settings (required in Render environment variables).
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=aquaalert

# Optional: for production diagnostics.
LOG_LEVEL=info
