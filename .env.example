# Copy this file to `.env` (do NOT commit `.env`), then fill in values.

# Used to sign JWTs. Change this in production.
JWT_SECRET=change-this-to-a-long-random-string

# MongoDB connection settings (required in Render environment variables).
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=aquaalert

# If your MongoDB password contains special characters like @, :, /, ?, or #,
# URL-encode it in the URI. Example: `Shubham@aquaalert` -> `Shubham%40aquaalert`.

# Optional MongoDB client tuning.
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=20000
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=0

# Supabase Storage (used for permanent report/completion/QR images).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_BUCKET=YOUR_BUCKET_NAME
SUPABASE_SERVICE_ROLE_KEY=PASTE_REAL_SERVICE_ROLE_SECRET_HERE

# Maximum allowed GPS accuracy (meters) for report/worker submissions.
# Increase if users report repeated low-accuracy errors in weak GPS conditions.
MAX_LOCATION_ACCURACY_M=300
MAX_REPORT_LOCATION_ACCURACY_M=300
MAX_WORKER_LOCATION_ACCURACY_M=800
MAX_WORKER_COMPLETION_ACCURACY_M=800

# Optional: for production diagnostics.
LOG_LEVEL=info
